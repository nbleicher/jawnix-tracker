{$JAWNIX_DOMAIN:jawnix.com} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy api:8001
	}

	redir / /login.html 302
	redir /index.html /login.html 302
	redir /login /login.html 308
	redir /portal /portal.html 308

	root * /srv/static
	file_server

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer-when-downgrade
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}
