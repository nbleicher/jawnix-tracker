{
	admin off
	auto_https off
}

:{$PORT:8080} {
	bind 0.0.0.0
	root * /app

	handle /healthz {
		respond "ok" 200
	}

	@api_preflight {
		path /api/*
		method OPTIONS
	}
	handle @api_preflight {
		reverse_proxy 127.0.0.1:{$JAWNIX_API_PORT:8001}
	}

	handle /api/auth/* {
		reverse_proxy 127.0.0.1:{$JAWNIX_API_PORT:8001}
	}

	handle /api/* {
		forward_auth 127.0.0.1:{$JAWNIX_API_PORT:8001} {
			uri /api/auth/check
		}

		reverse_proxy 127.0.0.1:{$JAWNIX_API_PORT:8001}
	}

	handle /login.html {
		file_server
	}

	handle /login {
		redir * /login.html 308
	}

	handle {
		@no_session not header Cookie *jawnix_session=*
		redir @no_session /login.html 303

		forward_auth 127.0.0.1:{$JAWNIX_API_PORT:8001} {
			uri /api/auth/check
			header_up X-Jawnix-Auth-Redirect /login.html
		}

		try_files {path} /index.html
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer-when-downgrade
	}
}
