{
	admin off
	auto_https off
}

0.0.0.0:{$PORT:8080} {
	root * /app

	handle /healthz {
		respond "ok" 200
	}

	@protected not path /healthz
	basic_auth @protected {
		{$JAWNIX_BASIC_AUTH_USER} {$JAWNIX_BASIC_AUTH_HASH}
	}

	try_files {path} /index.html
	file_server

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer-when-downgrade
	}
}
