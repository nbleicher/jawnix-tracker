# Public application
JAWNIX_DOMAIN=jawnix.com
JAWNIX_PUBLIC_BASE_URL=https://jawnix.com
JAWNIX_ENABLE_BILLING=false
JAWNIX_COOKIE_SECURE=true
JAWNIX_SESSION_SECRET=GENERATE_A_RANDOM_64_CHARACTER_VALUE
JAWNIX_SESSION_TTL_SECONDS=86400

# PostgreSQL (not exposed publicly)
POSTGRES_DB=jawnix
POSTGRES_USER=jawnix
POSTGRES_PASSWORD=GENERATE_A_LONG_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://jawnix:GENERATE_A_LONG_DATABASE_PASSWORD@postgres:5432/jawnix

# Supabase Auth only
JAWNIX_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
JAWNIX_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Slack interactive approvals
SLACK_BOT_TOKEN=xoxb-YOUR-TOKEN
SLACK_SIGNING_SECRET=YOUR_SIGNING_SECRET
SLACK_CHANNEL_ID=C0123456789
SLACK_APPROVER_USER_IDS=U0123456789

# Resend CSV delivery
RESEND_API_KEY=re_YOUR_KEY
RESEND_WEBHOOK_SECRET=whsec_YOUR_SECRET
JAWNIX_BATCH_FROM_EMAIL=Jawnix Batches <batches@jawnix.com>
JAWNIX_BATCH_DIR=/srv/jawnix/batches
JAWNIX_BATCH_RETENTION_DAYS=30

# Allocation and workers
JAWNIX_GLOBAL_COOLDOWN_DAYS=7
JAWNIX_WORKER_POLL_SECONDS=2
JAWNIX_WORKER_ID=vps-worker-1
JAWNIX_JOB_LOCK_TIMEOUT_SECONDS=900

# Scraper synchronization. The command operates on the VPS copy/mount, never
# on the original attached Mac folder.
JAWNIX_SCRAPER_DB_PATH=/data/health_leads/data/leads.db
JAWNIX_SCRAPER_COMMAND=
JAWNIX_SCRAPER_HOUR_UTC=3
JAWNIX_NPPES_INDEX_URL=https://download.cms.gov/nppes/NPI_Files.html

# Encrypted offsite backup (Restic supports S3-compatible repositories)
RESTIC_REPOSITORY=s3:https://s3.example.com/jawnix-backups
RESTIC_PASSWORD=GENERATE_A_SEPARATE_BACKUP_ENCRYPTION_PASSWORD
AWS_ACCESS_KEY_ID=YOUR_BACKUP_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_BACKUP_SECRET_KEY
AWS_DEFAULT_REGION=us-east-1
JAWNIX_BACKUP_HOUR_UTC=4
JAWNIX_BASEBACKUP_DAY_UTC=0
